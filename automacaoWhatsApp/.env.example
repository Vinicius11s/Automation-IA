# ============================================================
# .env.example — copie para .env e preencha os valores
# NUNCA commite o .env. Está no .gitignore.
# ============================================================

# --- Evolution API ---
EVOLUTION_API_URL=https://sua-instancia-evolution.dominio.com
EVOLUTION_API_KEY=sua-chave-aqui
EVOLUTION_INSTANCE=NomeDaInstancia

# --- CRM API ---
CRM_API_URL=https://sua-api-crm.dominio.com
CRM_MASTER_KEY=sua-chave-master-aqui

# --- Supabase ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=sua-service-role-key-aqui

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_DEBOUNCE_SECONDS=2.5

# --- LLMs ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL_CLASSIFIER=gpt-4.1-mini
OPENAI_MODEL_EXTRACTOR=gpt-3.5-turbo
OPENAI_MODEL_ASSISTANT=gpt-3.5-turbo

# --- Anthropic (opcional, para uso futuro) ---
ANTHROPIC_API_KEY=sk-ant-...
