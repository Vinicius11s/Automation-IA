# OpenAI (usado pelo morning.mjs para classificar tickets)
# Encontre em: platform.openai.com → API Keys
OPENAI_API_KEY=sk-...

# Supabase
# Encontre em: supabase.com → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase Service Role (apenas server-side, nunca expor no client)
# Encontre em: Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# URL do app (opcional, padrão: http://localhost:3000)
# SUPPORTOPS_URL=http://localhost:3000

# Chatbase — sugestão automática de resposta para tickets FAQ
# Encontre em: chatbase.co → Dashboard → Workspace Settings → API Keys
CHATBASE_API_KEY=your-chatbase-api-key
# Encontre em: chatbase.co → seu Agente → Settings → General → Chatbot ID
CHATBASE_CHATBOT_ID=your-chatbot-id

# Webhooks de automação (n8n ou similar — nunca expor no client)
# Cancelamento / Reembolso — consulta dados do aluno no CRM
WEBHOOK_CANCELAMENTO_CONSULTA=https://your-n8n-instance/webhook/your-path
# Finalizar — recebe { mensagem, email } e envia ao departamento responsável via WhatsApp
WEBHOOK_CANCELAMENTO_FINALIZAR=https://your-n8n-instance/webhook/your-path
